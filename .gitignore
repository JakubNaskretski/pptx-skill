# Authoring working state — transient, regenerated from source decks
authoring/workspace/*
!authoring/workspace/.gitkeep

# Source decks (often sensitive client material) — never tracked
*.pptx

# Built consumer artifacts
authoring/dist/
*.zip

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
