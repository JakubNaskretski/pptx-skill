# Authoring working state — transient, regenerated from source decks.
# Two exceptions: the workspace tag vocab seed, and the predigested
# example *skeletons* so the agent has a layout vocabulary on a
# fresh clone. Themes/decks/assets stay per-user and gitignored.
authoring/workspace/*
!authoring/workspace/.gitkeep
!authoring/workspace/tag_vocab.yaml

!authoring/workspace/skeletons/
authoring/workspace/skeletons/*
!authoring/workspace/skeletons/standard_templates_*/
!authoring/workspace/skeletons/standard_templates_*/**
!authoring/workspace/skeletons/title_and_breaks_*/
!authoring/workspace/skeletons/title_and_breaks_*/**

# Predigested example themes — ship the palette + master alongside the
# predigested skeletons above so a fresh clone can compose the demo
# decks without re-ingesting. User-ingested themes (anything else)
# stay per-user/gitignored via the workspace/* rule above.
!authoring/workspace/themes/
authoring/workspace/themes/*
!authoring/workspace/themes/standard_templates/
!authoring/workspace/themes/standard_templates/**
!authoring/workspace/themes/title_and_breaks/
!authoring/workspace/themes/title_and_breaks/**

# Source decks (often sensitive client material) — never tracked,
# except the canonical example deck binaries under examples/ so a
# fresh clone has them on hand to ingest if/when the user wants
# matching themes/assets in their workspace.
*.pptx
!examples/*.pptx
# Master.pptx of the predigested example themes — needed so compose
# can render against the right host on a fresh clone.
!authoring/workspace/themes/standard_templates/master.pptx
!authoring/workspace/themes/title_and_breaks/master.pptx

# Built consumer artifacts
authoring/dist/
*.zip

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
.claude/
*.swp

# Local-only handover / session notes
HANDOVER.md

# Local test inputs / sample bundles — keep private decks + reference
# bundles out of the repo. Source .pptx is already covered by *.pptx,
# but the rest of a sample prompt-bundle (index.json, brand.md, brief.md,
# theme.yaml) is not — this catches the whole directory.
TestData/
.agent-worktrees/
